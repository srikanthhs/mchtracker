rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // Helper to check role via exists and get
    function hasRole(role) {
      return isSignedIn() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    function isAdmin() { return hasRole('admin'); }

    // --- VALIDATION HELPERS ---
    function isValidPatient(data) {
      return data.n is string && data.n.size() <= 100
        && data.b is string && data.b.size() <= 64;
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() <= 100
        && data.role in ['admin', 'dph_officer', 'bdo', 'viewer']
        && data.active is bool;
    }

    // --- COLLECTIONS ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && (userId == request.auth.uid || isAdmin()) && isValidUser(incoming());
      allow update: if (isAdmin() || (isSignedIn() && userId == request.auth.uid)) 
                    && isValidUser(incoming()) 
                    && (isAdmin() || incoming().role == existing().role);
      allow delete: if isAdmin();
    }

    match /patients/{patientId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        isAdmin() || hasRole('dph_officer') || hasRole('viewer') ||
        (hasRole('bdo') && resource.data.b == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.block)
      );
      
      allow create: if (isAdmin() || hasRole('dph_officer') || hasRole('bdo')) && isValidId(patientId) && isValidPatient(incoming());
      allow update: if (isAdmin() || hasRole('dph_officer') || hasRole('bdo')) && isValidPatient(incoming());
      allow delete: if isAdmin();
    }

    match /alert_schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('dph_officer');
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update: if hasRole('admin') || hasRole('dph_officer');
      allow delete: if isAdmin();
    }
  }
}
